{
  "manifest_version": 3,
  "name": "Quick Percentage Calculator",
  "version": "2.3",
  "description": "Quickly calculate percentage discounts and percentage differences between numbers.",

  "browser_specific_settings": {
    "gecko": {
      "id": "{e356bca0-6dd5-48ae-914b-ae7df79b5372}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "icons": {
